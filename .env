# Absolute path to the JBoss EAP log directory on the host machine.
# Example (Linux/macOS):
# JBOSS_EAP_LOG_DIR=/opt/jboss-eap/standalone/log
# Example (Windows + Docker Desktop; adjust to your shared drive/mount style):
# JBOSS_EAP_LOG_DIR=/run/desktop/mnt/host/c/Users/<YOUR_USER>/jboss-eap/standalone/log
JBOSS_EAP_LOG_DIR=./target/server/standalone/log

# Leave empty on Docker Desktop / standard Linux Docker.
# If you use Podman with SELinux labeling, set to :Z
VOLUME_SELINUX_SUFFIX=
